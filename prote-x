serve(async (req) => {
  const url = new URL(req.url);

  if (req.method === "OPTIONS") {
    return new Response(null, {
      headers: {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type",
      },
    });
  }

  if (url.pathname.startsWith("/script/")) {
    const token = url.pathname.split("/")[2];
    const result = await KV.get<string>(["scripts", token]);
    const scriptData = result.value;

    if (!scriptData) {
      return new Response(accessDeniedPage(), {
        status: 403,
        headers: { "Content-Type": "text/html", "Access-Control-Allow-Origin": "*" },
      });
    }

    const userAgent = req.headers.get("User-Agent") || "";
    if (userAgent.includes("Roblox") || userAgent.includes("game") || userAgent.includes("HttpClient")) {
      return new Response(scriptData, {
        headers: { "Content-Type": "text/plain", "Access-Control-Allow-Origin": "*" },
      });
    }

    return new Response(accessDeniedPage(), {
      status: 403,
      headers: { "Content-Type": "text/html", "Access-Control-Allow-Origin": "*" },
    });
  }

  if (url.pathname === "/protect" && req.method === "POST") {
    try {
      const formData = await req.formData();
      const file = formData.get("file");
      if (!file || typeof file === "string") {
        return new Response(JSON.stringify({ error: "No file provided" }), {
          status: 400,
          headers: { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" },
        });
      }
      const content = await file.text();
      const token = generateToken();
      await KV.set(["scripts", token], content);
      const scriptUrl = url.origin + "/script/" + token;
      return new Response(JSON.stringify({ success: true, token, url: scriptUrl }), {
        headers: { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" },
      });
    } catch (error) {
      return new Response(JSON.stringify({ error: error.message }), {
        status: 500,
        headers: { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" },
      });
    }
  }

