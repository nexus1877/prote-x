result = result.replace(/\/\/.*$/gm, '');
result = result.replace(/\/\*[\s\S]*?\*\//g, '');

if (optControl) result = controlFlowObfuscation(result);
if (optXOR) result = xorObfuscation(result);
if (optBase64) result = base64Encode(result);
if (optAntiDebug) result = antiDebugWrapper(result);

const finalScript = PREREQUISITE + '\n\n' + result;

const formData = new FormData();
formData.append('file', new Blob([finalScript], { type: 'text/plain' }), currentFileName || 'script.lua');

const response = await fetch(WORKER_URL + '/protect', {
method: 'POST',
body: formData
});

const data = await response.json();

if (data.error) {
statusEl.textContent = 'Error: ' + data.error;
statusEl.className = 'status error';
return;
}

const loadstringOutput = 'loadstring(game:HttpGet("' + data.url + '"))()';
outputContent.textContent = loadstringOutput;
outputArea.classList.remove('hidden');
statusEl.textContent = 'Protection completed successfully';
statusEl.className = 'status success';

} catch (err) {
statusEl.textContent = 'Error: ' + err.message;
statusEl.className = 'status error';
} finally {
protectBtn.disabled = false;
}
});

function xorObfuscation(code) {
const key = Math.floor(Math.random() * 256);
let encrypted = '';
for (let i = 0; i < code.length; i++) {
encrypted += String.fromCharCode(code.charCodeAt(i) ^ key);
}
return '-- XOR key: ' + key + '\n' + encrypted;
}

function base64Encode(code) {
return btoa(unescape(encodeURIComponent(code)));
}

function controlFlowObfuscation(code) {
const lines = code.split('\n');
let result = [];
for (let line of lines) {
if (line.trim().startsWith('if') || line.trim().startsWith('while') || line.trim().startsWith('for')) {
result.push(line);
result.push('    if (' + (Math.random() > 0.5 ? 'true' : 'false') + ') then end');
} else if (line.trim().startsWith('return')) {
result.push('if (' + (Math.random() > 0.5 ? 'true' : 'false') + ') then ' + line + ' end');
} else {
result.push(line);
}
}
return result.join('\n');
}

function antiDebugWrapper(code) {
return '\nlocal function checkDebug()\n    if debug and debug.getinfo then\n        error("Debugging detected!")\n    end\nend\ncheckDebug()\n' + code;
}

